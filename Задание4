m = int(input('Введите первое натуральное число: '))
n = int(input('Введите второе натуральное число, при этом чтобы оно было больше предыдущего, либо равно ему: '))
if m < n:
    for i in range(m, n + 1):
        if (i % 17 == 0) or (i % 10 == 9) or (i % 3 == 0 and i % 5 == 0):
            print(i)
